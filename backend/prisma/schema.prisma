datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  GIRL
  BOY
  SECRET_COP
  ADMIN
}

enum AlertStatus {
  ACTIVE
  RESOLVED
}

model User {
  id            String   @id @default(uuid())
  phone         String   @unique
  email         String?  @unique
  password      String?
  fullName      String
  address       String?
  workAddress   String?  // New: Office location for Secret Cops
  profession    String?  // New: Job role for Secret Cops
  gender        String?
  role          Role     @default(BOY)
  isVerified    Boolean  @default(false)
  isSecretCopPending Boolean @default(false) 
  latitude      Float?   // Permanent Registration Latitude
  longitude     Float?   // Permanent Registration Longitude
  points        Int      @default(0)    
  level         Int      @default(1)    // New: User Rank Level
  awards        Int      @default(0)    // New: Count of Admin approvals
  pushToken     String?  // Expo push notification token
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  contacts      EmergencyContact[]
  alerts        Alert[]
  responses     SafetyResponse[]
  suggestions   HazardSuggestion[] // New: Danger road reports
  lastLocation  Location?
  gpsHistory    GpsHistory[]
  guardianSessions GuardianTimerSession[]
}

model EmergencyContact {
  id             String   @id @default(uuid())
  name           String
  phone          String
  relationship   String   // mother, father, brother, sister, or guardian
  secondaryPhone String?  // Optional secondary emergency contact number
  status         String   @default("PENDING") // PENDING, APPROVED, REJECTED
  userId         String
  user           User     @relation(fields: [userId], references: [id])
}

model RedZone {
  id          String   @id @default(uuid())
  name        String   // Area Name
  latitude    Float
  longitude   Float
  destLatitude Float?  // For ROAD mode
  destLongitude Float? // For ROAD mode
  pathData    String?  // JSON string of coordinates for curves
  radius      Float    @default(500) // Default radius in meters
  caseCount   Int      @default(1)   // Number of cases recorded here
  type        String   @default("CRIME") // CRIME, DARK_AREA, ANIMAL_ZONE, SHARP_TURN
  crimeType   String?  // theft, assault, etc.
  incidentDate DateTime? @default(now())
  startTime   String?  // e.g., "10:00 PM"
  endTime     String?  // e.g., "04:00 AM"
  riskLevel   Int      @default(1)   // Calculated on backend
  description String?
  isVerified  Boolean  @default(true) // False if suggested by user but not approved by admin
  createdAt   DateTime @default(now())
  guardianSessions GuardianTimerSession[]
}

model HazardSuggestion {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  name        String
  latitude    Float
  longitude   Float
  destLatitude Float?
  destLongitude Float?
  pathData    String?  // Store JSON array of coordinates for curves/paths
  startTime   String?
  endTime     String?
  type        String   // DARK_AREA, ANIMAL_ZONE, SHARP_TURN, SAFE_ZONE, CRIME
  description String?
  caseCount     Int?     @default(0)
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt   DateTime @default(now())
}

model Alert {
  id                String          @id @default(uuid())
  userId            String
  user              User            @relation(fields: [userId], references: [id])
  latitude          Float
  longitude         Float
  status            AlertStatus     @default(ACTIVE)
  triggerType       String          @default("TOUCH") // TOUCH, VOICE
  voiceNote         String?         // Which phrase triggered it
  evidenceToken     String?         @unique // Secure random token
  evidenceExpiresAt DateTime?       // 24 hours expiry
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  responses         SafetyResponse[]
  tracking          AlertTracking[]
  evidence          EvidenceFile[]
  parentNotifications ParentNotification[]
}

model ParentNotification {
  id          String   @id @default(uuid())
  parentPhone String
  alertId     String
  alert       Alert    @relation(fields: [alertId], references: [id], onDelete: Cascade)
  isDelivered Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model AlertTracking {
  id        String   @id @default(uuid())
  alertId   String
  alert     Alert    @relation(fields: [alertId], references: [id])
  latitude  Float
  longitude Float
  createdAt DateTime @default(now())
}

model EvidenceFile {
  id        String   @id @default(uuid())
  alertId   String
  alert     Alert    @relation(fields: [alertId], references: [id])
  fileUrl   String   // path to file
  fileType  String   // "AUDIO" or "VIDEO"
  createdAt DateTime @default(now())
}

model SafetyResponse {
  id        String   @id @default(uuid())
  alertId   String
  alert     Alert    @relation(fields: [alertId], references: [id])
  helperId  String
  helper    User     @relation(fields: [helperId], references: [id])
  status    String   @default("PENDING") // PENDING, ACCEPTED, REJECTED, COMPLETED
  createdAt DateTime @default(now())
}

model Location {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  latitude  Float
  longitude Float
  updatedAt DateTime @updatedAt
}

model News {
  id        String   @id @default(uuid())
  title     String
  content   String
  latitude  Float?
  longitude Float?
  source    String?
  type      String   @default("INFO")
  createdAt DateTime @default(now())
}

model GpsHistory {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  latitude  Float
  longitude Float
  batteryLevel Float?
  timestamp DateTime @default(now())

  @@index([userId])
  @@index([timestamp])
}

model GuardianTimerSession {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  zoneId          String
  zone            RedZone  @relation(fields: [zoneId], references: [id])
  entryTime       DateTime
  expectedExitTime DateTime
  alertTime       DateTime
  status          String   @default("ACTIVE") // ACTIVE, COMPLETED, EXPIRED
  createdAt       DateTime @default(now())

  @@index([userId])
  @@index([status])
}
