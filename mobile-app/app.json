{
  "expo": {
    "name": "Chetna",
    "slug": "chetna",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Chetna to use your location to provide safety alerts and emergency response.",
          "isAndroidBackgroundLocationEnabled": true
        }
      ],
      [
        "@dev-amirzubair/react-native-voice",
        {
          "microphonePermission": "Allow Chetna to use the microphone for voice-activated emergency alerts."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#d63384"
        }
      ],
      "./plugins/withVolumeKey"
    ],
    "updates": {
      "enabled": false,
      "fallbackToCacheTimeout": 0
    },
    "platforms": [
      "ios",
      "android"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.anonymous.chetna"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "config": {
        "firebase": {
          "apiKey": "AIzaSyD5RPzSPmKfHaY3KF2Pp3_8IN_6bK8B5Pg",
          "authDomain": "chetna-4fa07.firebaseapp.com",
          "projectId": "chetna-4fa07",
          "storageBucket": "chetna-4fa07.firebasestorage.app",
          "messagingSenderId": "816536192086",
          "appId": "1:816536192086:web:006c1bfa01b44e815067f7",
          "measurementId": "G-79SYQ8Q7FB"
        }
      }
    }
  }
}
